extends ./partial/layout.pug
block linkcss
    link(href="/vendor/bootstrap5/css/bootstrap.min.css" rel="stylesheet")
    link(rel="stylesheet" href="/vendor/fontawesome6/css/all.min.css")
    link(href="/vendor/datatables/css/dataTables.bootstrap5.min.css" rel="stylesheet")
    link(href="/vendor/datatables/css/responsive.dataTables.min.css" rel="stylesheet")
    link(rel="stylesheet", href="/css/viewUser.css")
    link(rel="stylesheet", href="/css/pageCommon.css")
block content
    .container-fluid.py-4
        h2.mb-4.text-primary
            i.fas.fa-users-gear.me-2
            | User Management

        .card.card-custom.p-4
            h5.card-title.text-primary
                i.fas.fa-table.me-2
                | User List
            .table-responsive
                table#userTable.table.table-striped.table-hover.w-100
                    thead.table-light
                        tr
                            th
                                i.fas.fa-id-card
                                | Username
                            th
                                i.fas.fa-envelope
                                | Email
                            th
                                i.fas.fa-shield-alt
                                | Role
                            th
                                i.fas.fa-user-tie
                                | Employee Name
                            th
                                i.fas.fa-user-tag
                                | Customer Name
                            th.dt-center
                                i.fas.fa-sitemap
                                | Managed Sites
                            th
                                i.fas.fa-wrench
                                | Actions
                    tbody#bodyTable

    // Modal for Site List
    #siteListModal.modal.fade(tabindex="-1" aria-labelledby="siteListModalLabel" aria-hidden="true")
        .modal-dialog.modal-xl
            .modal-content
                .modal-header.bg-primary.text-white
                    h5#siteListModalLabel.modal-title
                        i.fas.fa-sitemap.me-2
                        | Managed Sites for
                        span#modalUsername
                        |  (
                        span#modalSiteCount
                        |  sites)
                    button.btn-close.btn-close-white(type="button" data-bs-dismiss="modal" aria-label="Close" onclick="closeModal()")
                .modal-body
                    .table-responsive
                        table#siteListTable.table.table-sm.table-hover
                            thead
                                tr
                                    th SiteId
                                    th Location
                                    th Status
                                    th Last Data Time
                                    th Alarm
                            tbody#siteListContainer
                .modal-footer
                    button.btn.btn-secondary(type="button" data-bs-dismiss="modal" onclick="closeModal()") Close

block linkcriptbody
    script(src="/vendor/jquery/jquery-3.7.1.min.js")
    script(src="/vendor/bootstrap5/js/bootstrap.bundle.min.js")
    script(src="/vendor/datatables/js/dataTables.min.js")
    script(src="/vendor/datatables/js/dataTables.bootstrap5.min.js")
    script(src="/vendor/datatables/js/dataTables.buttons.min.js")
    script(src="/vendor/datatables/js/buttons.bootstrap5.min.js")
    script(src="/vendor/jszip/jszip.min.js")
    script(src="/vendor/pdfmake/pdfmake.min.js")
    script(src="/vendor/pdfmake/vfs_fonts.js")
    //script(src="/vendor/datatables/js/buttons.html5.min.js")
    //script(src="/vendor/datatables/js/buttons.print.min.js")
    script(src="/vendor/datatables/js/dataTables.responsive.min.js")
    script(src="/js/hostname.js")
    script(src="/js/viewUser.js")
    script(src="/js/util.js")
