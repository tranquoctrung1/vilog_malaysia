extends ./partial/layout.pug
block linkcss
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css")
    link(rel="stylesheet", href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css")
    link(rel="stylesheet", href="https://cdn.datatables.net/2.0.8/css/dataTables.bootstrap5.min.css")
    link(rel="stylesheet", href="https://cdn.datatables.net/buttons/3.0.2/css/buttons.bootstrap5.min.css")
    link(rel="stylesheet", href="https://cdn.datatables.net/responsive/3.0.2/css/responsive.bootstrap5.min.css")
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/tom-select/dist/css/tom-select.bootstrap5.min.css")
    link(rel="stylesheet", href="/css/configVilog.css")
    link(rel="stylesheet", href="/css/pageCommon.css")
block content
    .container-fluid.py-4
        .card.card-config
            .config-header
                i.fas.fa-gear.me-2
                | Vilog Remote Configuration (Table View)
            .card-body.p-4.p-lg-5
                .table-responsive.mb-4
                    table.table.table-striped.table-bordered.table-hover#siteListTable(width="100%")
                        thead.thead-dark
                            tr
                                th.text-center No
                                th.text-center Site ID
                                th.text-center Location
                                th.text-center Meter Type
                                th.text-center Logger ID
                                th.text-center Send Time
                                th.text-center Log Time
                                th.text-center Latitude
                                th.text-center Longitude
                                th.text-center Status
                        tbody

